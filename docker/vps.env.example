# Cấu hình bảo mật cho Database
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# Cấu hình xác thực cho Better Auth (BẮT BUỘC)
# Dùng lệnh `openssl rand -base64 32` để sinh ra chuỗi bí mật
BETTER_AUTH_SECRET=YOUR_BETTER_AUTH_SECRET_HERE

# Cấu hình đường dẫn Public URL của bạn (BẮT BUỘC)
# Ví dụ: https://paperclip.yourdomain.com
PAPERCLIP_PUBLIC_URL=https://YOUR_DOMAIN_OR_IP_HERE

# API Keys cho AI models (Tuỳ chọn nếu sử dụng)
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
